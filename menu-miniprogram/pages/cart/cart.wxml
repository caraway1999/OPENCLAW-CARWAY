<view class="container">
  <!-- 空购物车 -->
  <view class="empty-cart" wx:if="{{cart.length === 0}}">
    <view class="empty-icon"></view>
    <text class="empty-text">购物车空空如也</text>
    <view class="go-shopping-btn" bindtap="goToMenu">去点餐</view>
  </view>

  <!-- 购物车列表 -->
  <view class="cart-list" wx:if="{{cart.length > 0}}">
    <!-- 全选 -->
    <view class="select-all card">
      <view class="checkbox {{selectAll ? 'checked' : ''}}" bindtap="toggleSelectAll"></view>
      <text>全选</text>
      <view class="clear-cart" bindtap="clearCart">清空购物车</view>
    </view>

    <!-- 商品列表 -->
    <view class="cart-item card" wx:for="{{cart}}" wx:key="_id">
      <view class="checkbox {{item.selected ? 'checked' : ''}}" bindtap="toggleSelect" data-index="{{index}}"></view>
      <image src="{{item.image}}" mode="aspectFill" class="cart-image"></image>
      <view class="cart-info">
        <view class="cart-name">{{item.name}}</view>
        <view class="cart-desc">{{item.description}}</view>
        <view class="cart-bottom">
          <view class="cart-price">{{item.price}}</view>
          <view class="quantity-control">
            <view class="quantity-btn minus" bindtap="decreaseQuantity" data-index="{{index}}">-</view>
            <text class="quantity-text">{{item.quantity}}</text>
            <view class="quantity-btn plus" bindtap="increaseQuantity" data-index="{{index}}">+</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="remark card">
      <text class="remark-label">订单备注</text>
      <input class="remark-input" placeholder="请输入备注信息（如：不要辣、少放盐等）" bindinput="onRemarkInput" value="{{remark}}"/>
    </view>

    <!-- 用餐方式 -->
    <view class="dining-mode card">
      <text class="mode-label">用餐方式</text>
      <view class="mode-options">
        <view class="mode-option {{diningMode === '堂食' ? 'active' : ''}}" bindtap="setDiningMode" data-mode="堂食">堂食</view>
        <view class="mode-option {{diningMode === '打包' ? 'active' : ''}}" bindtap="setDiningMode" data-mode="打包">打包</view>
        <view class="mode-option {{diningMode === '外卖' ? 'active' : ''}}" bindtap="setDiningMode" data-mode="外卖">外卖</view>
      </view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="settlement-bar" wx:if="{{cart.length > 0}}">
    <view class="settlement-info">
      <view class="total-label">合计</view>
      <view class="total-price">{{totalPrice}}</view>
    </view>
    <view class="settlement-btn {{selectedCount > 0 ? '' : 'disabled'}}" bindtap="submitOrder">
      结算{{selectedCount > 0 ? '(' + selectedCount + ')' : ''}}
    </view>
  </view>
</view>