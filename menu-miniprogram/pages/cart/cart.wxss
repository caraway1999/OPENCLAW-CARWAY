/* 购物车页样式 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23ddd"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>');
  background-size: contain;
  background-repeat: no-repeat;
  margin-bottom: 30rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.go-shopping-btn {
  background-color: #ff6b35;
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 购物车列表 */
.cart-list {
  padding-bottom: 160rpx;
}

.select-all {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  margin-right: 20rpx;
  position: relative;
}

.checkbox.checked {
  background-color: #ff6b35;
  border-color: #ff6b35;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 6rpx;
  width: 12rpx;
  height: 20rpx;
  border: solid #fff;
  border-width: 0 4rpx 4rpx 0;
  transform: rotate(45deg);
}

.clear-cart {
  margin-left: auto;
  color: #999;
  font-size: 24rpx;
}

/* 购物车商品 */
.cart-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.cart-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.cart-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.cart-desc {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cart-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cart-price {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: bold;
}

.cart-price::before {
  content: '¥';
  font-size: 24rpx;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.quantity-btn.minus {
  background-color: #fff;
  border: 2rpx solid #ff6b35;
  color: #ff6b35;
}

.quantity-btn.plus {
  background-color: #ff6b35;
  color: #fff;
}

.quantity-text {
  font-size: 28rpx;
  color: #333;
  margin: 0 16rpx;
  min-width: 40rpx;
  text-align: center;
}

/* 备注 */
.remark {
  padding: 20rpx;
}

.remark-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.remark-input {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 26rpx;
}

/* 用餐方式 */
.dining-mode {
  padding: 20rpx;
}

.mode-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.mode-options {
  display: flex;
  gap: 20rpx;
}

.mode-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.mode-option.active {
  border-color: #ff6b35;
  color: #ff6b35;
  background-color: rgba(255, 107, 53, 0.1);
}

/* 结算栏 */
.settlement-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  padding-bottom: env(safe-area-inset-bottom);
}

.settlement-info {
  display: flex;
  align-items: center;
}

.total-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 16rpx;
}

.total-price {
  font-size: 36rpx;
  color: #ff6b35;
  font-weight: bold;
}

.total-price::before {
  content: '¥';
  font-size: 28rpx;
}

.settlement-btn {
  background-color: #ff6b35;
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.settlement-btn.disabled {
  background-color: #ccc;
}