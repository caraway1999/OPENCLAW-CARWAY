/* 订单页样式 */
.status-tabs {
  display: flex;
  background-color: #fff;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.status-tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 12rpx 0;
  position: relative;
}

.status-tab.active {
  color: #ff6b35;
  font-weight: bold;
}

.status-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #ff6b35;
  border-radius: 2rpx;
}

/* 订单列表 */
.order-list {
  padding-bottom: 20rpx;
}

.order-item {
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-number {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 24rpx;
  color: #666;
}

.order-status.pending {
  color: #ff6b35;
}

.order-status.completed {
  color: #52c41a;
}

/* 订单内容 */
.order-content {
  padding: 16rpx 0;
}

.order-dish {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-dish:last-child {
  margin-bottom: 0;
}

.dish-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.dish-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.dish-quantity {
  font-size: 22rpx;
  color: #999;
}

.dish-price {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: bold;
}

.dish-price::before {
  content: '¥';
  font-size: 22rpx;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-time {
  font-size: 22rpx;
  color: #999;
}

.order-total {
  display: flex;
  align-items: center;
}

.total-label {
  font-size: 24rpx;
  color: #666;
}

.total-price {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: bold;
}

.total-price::before {
  content: '¥';
  font-size: 24rpx;
}

/* 订单操作 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  border: 2rpx solid #ddd;
  color: #666;
}

.action-btn.cancel {
  border-color: #ddd;
  color: #666;
}

.action-btn.pay {
  border-color: #ff6b35;
  background-color: #ff6b35;
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23ddd"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>');
  background-size: contain;
  background-repeat: no-repeat;
  margin-bottom: 30rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.go-order-btn {
  background-color: #ff6b35;
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}