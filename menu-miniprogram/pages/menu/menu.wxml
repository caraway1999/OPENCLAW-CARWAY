<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索菜品" bindinput="onSearch" value="{{searchKey}}"/>
    <view class="search-icon"></view>
  </view>

  <!-- 分类标签 -->
  <scroll-view scroll-x class="category-tabs">
    <view class="tab-item {{activeCategory === 'all' ? 'active' : ''}}" bindtap="switchCategory" data-category="all">全部</view>
    <view class="tab-item {{activeCategory === '热菜' ? 'active' : ''}}" bindtap="switchCategory" data-category="热菜">热菜</view>
    <view class="tab-item {{activeCategory === '凉菜' ? 'active' : ''}}" bindtap="switchCategory" data-category="凉菜">凉菜</view>
    <view class="tab-item {{activeCategory === '海鲜' ? 'active' : ''}}" bindtap="switchCategory" data-category="海鲜">海鲜</view>
    <view class="tab-item {{activeCategory === '汤类' ? 'active' : ''}}" bindtap="switchCategory" data-category="汤类">汤类</view>
    <view class="tab-item {{activeCategory === '主食' ? 'active' : ''}}" bindtap="switchCategory" data-category="主食">主食</view>
    <view class="tab-item {{activeCategory === '饮品' ? 'active' : ''}}" bindtap="switchCategory" data-category="饮品">饮品</view>
  </scroll-view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 菜品列表 -->
  <view class="dish-list" wx:if="{{!loading}}">
    <view class="dish-item card" wx:for="{{filteredDishes}}" wx:key="id" bindtap="showDishDetail" data-dish="{{item}}">
      <image src="{{item.image}}" mode="aspectFill" class="dish-image"></image>
      <view class="dish-info">
        <view class="dish-header">
          <view class="dish-name">{{item.name}}</view>
          <view class="dish-tags">
            <text class="tag cooking-tag" wx:if="{{item.cookingMethod}}">{{item.cookingMethod}}</text>
          </view>
        </view>
        <view class="dish-desc">{{item.description}}</view>
        <view class="dish-nutrition">
          <text class="nutrition-item" wx:if="{{item.weight}}">
            <text class="nutrition-icon">⚖️</text>{{item.weight}}g
          </text>
          <text class="nutrition-item" wx:if="{{item.calories}}">
            <text class="nutrition-icon">🔥</text>{{item.calories}}kcal
          </text>
        </view>
        <view class="dish-meta">
          <view class="dish-price">{{item.price}}</view>
          <view class="dish-sales">月售{{item.sales || 0}}份</view>
        </view>
        <view class="dish-actions" catchtap="stopPropagation">
          <view class="quantity-control" wx:if="{{getCartQuantity(item.id) > 0}}">
            <view class="quantity-btn minus" bindtap="decreaseQuantity" data-id="{{item.id}}">-</view>
            <text class="quantity-text">{{getCartQuantity(item.id)}}</text>
          </view>
          <view class="add-btn" bindtap="addToCart" data-dish="{{item}}">+</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && filteredDishes.length === 0}}">
    <text>暂无菜品</text>
  </view>

  <!-- 底部购物车栏 -->
  <view class="cart-bar" wx:if="{{cartCount > 0}}" bindtap="goToCart">
    <view class="cart-info">
      <view class="cart-icon-wrapper">
        <view class="cart-icon-bar"></view>
        <view class="cart-badge">{{cartCount}}</view>
      </view>
      <text class="cart-total">{{cartTotal}}</text>
    </view>
    <view class="checkout-btn">去结算</view>
  </view>

  <!-- 菜品详情弹窗 -->
  <view class="detail-modal {{showDetail ? 'active' : ''}}" bindtap="hideDishDetail">
    <view class="detail-content" catchtap="stopPropagation">
      <view class="detail-close" bindtap="hideDishDetail">×</view>
      <image src="{{currentDish.image}}" mode="aspectFill" class="detail-image"></image>
      <view class="detail-info">
        <view class="detail-name">{{currentDish.name}}</view>
        <view class="detail-desc">{{currentDish.description}}</view>
        
        <view class="detail-section">
          <view class="section-title">菜品构成</view>
          <view class="nutrition-grid">
            <view class="nutrition-card">
              <view class="nutrition-value">{{currentDish.weight || '-'}}</view>
              <view class="nutrition-label">重量(g)</view>
            </view>
            <view class="nutrition-card">
              <view class="nutrition-value">{{currentDish.calories || '-'}}</view>
              <view class="nutrition-label">热量(kcal)</view>
            </view>
            <view class="nutrition-card">
              <view class="nutrition-value">{{currentDish.cookingMethod || '-'}}</view>
              <view class="nutrition-label">烹饪方式</view>
            </view>
          </view>
        </view>
        
        <view class="detail-section" wx:if="{{currentDish.ingredients}}">
          <view class="section-title">配料清单</view>
          <view class="ingredients-text">{{currentDish.ingredients}}</view>
        </view>
        
        <view class="detail-footer">
          <view class="detail-price">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{currentDish.price}}</text>
          </view>
          <view class="detail-actions">
            <view class="quantity-control" wx:if="{{getCartQuantity(currentDish.id) > 0}}">
              <view class="quantity-btn minus" bindtap="decreaseQuantity" data-id="{{currentDish.id}}">-</view>
              <text class="quantity-text">{{getCartQuantity(currentDish.id)}}</text>
            </view>
            <view class="add-btn-large" bindtap="addToCartFromDetail">加入购物车</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>